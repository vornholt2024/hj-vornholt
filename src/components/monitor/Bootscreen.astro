---
import "./bootscreen.css";
---

<div class="boot-screen" id="bootScreen">

    <div class="boot-title">

        Developer Workspace

    </div>

    <div class="boot-status" id="bootStatus">

        Initializing...

    </div>

    <div class="progress">

        <div class="progress-bar" id="progressBar"></div>

    </div>

    <div class="boot-list">

        <div class="boot-item" id="item1">Astro</div>

        <div class="boot-item" id="item2">TypeScript</div>

        <div class="boot-item" id="item3">Odoo ERP</div>

        <div class="boot-item" id="item4">REST API</div>

        <div class="boot-item" id="item5">AI Services</div>

    </div>

</div>


